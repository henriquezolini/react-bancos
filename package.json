{
  "name": "react-bancos",
  "version": "0.5.0",
  "description": "Ícones dos principais bancos e fintechs do Brasil como componentes React — padronizados, fiéis às marcas e com metadados (nome, código COMPE, cor).",
  "keywords": [
    "react",
    "icons",
    "bancos",
    "brasil",
    "brazilian-banks",
    "fintech",
    "svg",
    "nubank",
    "itau",
    "pix"
  ],
  "license": "MIT",
  "author": "Henrique Zolini <henriquezolini@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquezolini/react-bancos.git"
  },
  "homepage": "https://henriquezolini.github.io/react-bancos/",
  "bugs": "https://github.com/henriquezolini/react-bancos/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons/*": "./icons/*"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "icons"
  ],
  "scripts": {
    "generate": "node scripts/build-icons.mjs",
    "docs": "node scripts/build-docs.mjs",
    "build": "npm run generate && tsup",
    "test": "npm run build && node scripts/smoke-test.mjs",
    "prepublishOnly": "npm test"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
